{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",

    "types": ["node"],
    "lib": ["ES2020"],

    "esModuleInterop": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,

    "skipLibCheck": true
  },
  "include": ["src"]
}
